{
  "name": "@factstr/factstr-node",
  "version": "0.4.1",
  "description": "TypeScript and Node language adapter for FACTSTR memory, SQLite, and PostgreSQL stores.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ricofritzsche/factstr"
  },
  "files": [
    "README.md",
    "index.js",
    "index.d.ts"
  ],
  "optionalDependencies": {
    "@factstr/factstr-node-darwin-arm64": "0.4.1",
    "@factstr/factstr-node-darwin-x64": "0.4.1",
    "@factstr/factstr-node-linux-x64-gnu": "0.4.1",
    "@factstr/factstr-node-win32-x64-msvc": "0.4.1"
  },
  "scripts": {
    "prepare:readme": "node ./scripts/prepare-readme.mjs",
    "build": "npm run prepare:readme && node ./scripts/build-package.mjs",
    "build:prebuilt:current": "node ./scripts/build-prebuilt-package.mjs",
    "pack:local": "npm pack",
    "pack:prebuilt:current": "node ./scripts/pack-prebuilt-package.mjs",
    "prepack": "npm run prepare:readme",
    "smoke:packed": "npm run build && npm run pack:local && npm run pack:prebuilt:current && npm --prefix smoke run install:packed && npm --prefix smoke run build && npm --prefix smoke run smoke"
  }
}
